// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "current_line_highlight": "all",
  "vertical_scroll_margin": 5,
  "lsp_results_location": "multi_buffer",
  "cli_default_open_behavior": "existing_window",
  "auto_indent_on_paste": false,
  "diff_view_style": "unified",
  // Ensure Jenkinsfile variants (e.g. Jenkinsfile.deploy) use Groovy/LSP
  "file_types": {
    "Groovy": ["Jenkinsfile", "Jenkinsfile.*"],
  },
  "agent_servers": {
    "gemini": {
      "type": "registry",
    },
    "github-copilot-cli": {
      "type": "registry",
    },
    "opencode": {
      "default_config_options": {
        "model": "opencode/deepseek-v4-flash-free",
      },
      "type": "registry",
    },
    "cursor": {
      "default_config_options": {
        "reasoning": "medium",
        "model": "claude-opus-4-8",
      },
      "type": "registry",
    },
  },
  "proxy": "",
  "git": {
    "inline_blame": {
      "show_commit_summary": false,
      "padding": 8,
      "delay_ms": 600,
    },
  },
  "show_signature_help_after_edits": false,
  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
    "default_height": 450.0,
    "default_width": 450.0,
    "keep_selection_on_copy": false,
    "font_weight": 500.0,
    "font_family": "VictorMono Nerd Font",
    "font_size": 14.0,
  },
  "active_pane_modifiers": {
    "border_size": 1.5,
    "inactive_opacity": 0.8,
  },
  "bottom_dock_layout": "full",
  "expand_excerpt_lines": 7,
  "excerpt_context_lines": 4,
  "code_lens": "menu",
  "centered_layout": {
    "left_padding": 0.4,
    "right_padding": 0.4,
  },
  "preview_tabs": {
    "enable_preview_multibuffer_from_code_navigation": true,
    "enable_preview_from_file_finder": false,
  },
  "seed_search_query_from_cursor": "selection",
  "use_smartcase_search": true,
  "agent": {
    "dock": "left",
    "flexible": false,
    "terminal_init_command": "",
    "default_height": 450.0,
    "default_width": 550.0,
    "favorite_models": [],
    "model_parameters": [],
  },
  "collaboration_panel": {
    "button": false,
    "default_width": 450.0,
  },
  "git_panel": {
    "dock": "right",
    "group_by": "staging",
    "show_count_badge": true,
    "default_width": 450.0,
    "file_icons": true,
    "tree_view": true,
  },
  "outline_panel": {
    "default_width": 450.0,
    "indent_size": 20.0,
    "dock": "left",
  },
  "project_panel": {
    "auto_open": {
      "on_drop": false,
      "on_paste": false,
      "on_create": false,
    },
    "hide_root": true,
    "git_status_indicator": true,
    "diagnostic_badges": true,
    "bold_folder_labels": false,
    "starts_open": false,
    "indent_size": 20.0,
    "entry_spacing": "standard",
    "default_width": 450.0,
  },
  "edit_predictions": {
    "provider": "copilot",
    "allow_data_collection": "no",
    "open_ai_compatible_api": {
      "model": "",
    },
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
  },
  "tabs": {
    "show_close_button": "hover",
    "show_diagnostics": "errors",
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_branch_status_icon": true,
  },
  "status_bar": {
    "active_encoding_button": "enabled",
    "show_active_file": true,
    "line_endings_button": true,
  },
  "restore_on_startup": "last_session",
  "diagnostics": {
    "inline": {
      "padding": 4,
      "min_column": 60,
      "enabled": true,
    },
  },
  "prettier": {
    "allowed": true,
  },
  "document_symbols": "on",
  "document_folding_ranges": "on",
  "semantic_tokens": "combined",
  "middle_click_paste": false,
  "completions": {
    "words_min_length": 2,
  },
  "line_ending": "prefer_lf",
  "format_on_save": "modifications_if_available",
  "code_actions_on_format": {
    "source.fixAll.eslint": true,
  },
  "vim": {
    "cursor_shape": {
      "insert": "bar",
    },
    "highlight_on_yank_duration": 190,
    "toggle_relative_line_numbers": true,
  },
  "gutter": {
    "min_line_number_digits": 3,
  },
  "relative_line_numbers": "wrapped",
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "which_key": {
    "enabled": true,
  },
  "autosave": "on_window_change",
  "rounded_selection": true,
  "selection_highlight": false,
  "cursor_blink": true,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "agent_ui_font_size": 16.0,
  "ui_font_family": ".ZedSans",
  "buffer_line_height": "standard",
  "buffer_font_weight": 600.0,
  "buffer_font_family": "Victor Mono",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
    "anthropic_retention": false,
  },
  "icon_theme": {
    "mode": "light",
    "light": "VSCode Icons for Zed (Light)",
    "dark": "VSCode Icons for Zed (Dark)",
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "ui_font_size": 16.0,
  "buffer_font_size": 15.0,
  "show_wrap_guides": true,
  "show_whitespaces": "all",
  "wrap_guides": [80, 100],
  "theme": {
    "mode": "light",
    "light": "GitHub Light",
    "dark": "GitHub Dark",
  },
  "command_aliases": {
    "zlog": "zed::OpenLog",
    "ca": "workspace::CopyPath",
    "cr": "workspace::CopyRelativePath",
    "gd": "git::BranchDiff",
    "tt": "theme::ToggleMode",
    "wo": "workspace::Open",
    "wr": "workspace::Reload",
    "wt": "git::Worktree",
  },
  "unnecessary_code_fade": 0.55,
  "theme_overrides": {
    "GitHub Light": {
      "editor.document_highlight.read_background": "#0969da3b",
      "editor.document_highlight.write_background": "#0969da28",
      "editor.active_line.background": "#0969da1f",
      "editor.active_line_number": "#0969da",
      "editor.line_number": "#8c959f",
      "syntax": {
        "comment": { "font_style": "italic" },
        "comment.doc": { "font_style": "italic" },

        "keyword": { "font_style": "italic" },
        "variable.special": { "font_style": "italic" },
        "emphasis": { "font_style": "italic" },

        "boolean": { "font_style": "italic" },
        "constant.builtin": { "font_style": "italic" },

        "type": { "font_weight": 700 },
        "type.builtin": { "font_weight": 700 },
        "namespace": { "font_weight": 700 },
        "attribute": { "font_weight": 700 },
      },
    },
    "GitHub Dark": {
      "editor.active_line.background": "#58a6ff1a",
      "editor.active_line_number": "#58a6ff",
      "editor.line_number": "#6e7681",
      "syntax": {
        "comment": { "font_style": "italic" },
        "comment.doc": { "font_style": "italic" },

        "keyword": { "font_style": "italic" },
        "variable.special": { "font_style": "italic" },
        "emphasis": { "font_style": "italic" },

        "boolean": { "font_style": "italic" },
        "constant.builtin": { "font_style": "italic" },

        "type": { "font_weight": 700 },
        "type.builtin": { "font_weight": 700 },
        "namespace": { "font_weight": 700 },
        "attribute": { "font_weight": 700 },
      },
    },
  },
  "global_lsp_settings": {
    "semantic_token_rules": [
      // { "token_type": "hyperlink", "underline": true, "style": ["link_uri"] },
      { "token_type": "hyperlink", "underline": true },
      {
        "token_type": "keyword",
        "font_style": "italic",
        "font_weight": "bold",
      },
      {
        "token_type": "type",
        "font_weight": "bold",
      },
      {
        "token_type": "namespace",
        "font_weight": "bold",
      },
      {
        "token_type": "class",
        "font_weight": "bold",
      },
    ],
  },
  "languages": {
    "Haskell": {
      "tab_size": 2,
      "formatter": "language_server",
      "format_on_save": "modifications_if_available",
    },
    "Rust": {
      "formatter": "language_server",
      "format_on_save": "modifications_if_available",
      "code_actions_on_format": {
        "source.fixAll.rust-analyzer": true,
      },
    },
    "Python": {
      "language_servers": ["ty", "!basedpyright", "..."],
      "formatter": [
        {
          "external": {
            "command": "isort",
            "arguments": ["--profile", "black", "-"],
          },
        },
        { "external": { "command": "black", "arguments": ["--quiet", "-"] } },
      ],
      "format_on_save": "modifications_if_available",
    },
    "Markdown": {
      "formatter": "language_server",
      "format_on_save": "modifications_if_available",
    },
  },
  "lsp": {
    "hls": {
      "initialization_options": {
        "haskell": {
          "formattingProvider": "fourmolu",
        },
      },
    },
    "eslint": {
      "settings": {
        "workingDirectory": {
          "mode": "auto",
        },
      },
    },
    "groovy": {
      // Groovy LSP is a Java jar launched by a thin wrapper. Without java on PATH
      // the wrapper panics with Os NotFound (exactly the Zed startup error).
      "binary": {
        "path": "~/.local/bin/groovy-language-server",
        "env": {
          "JAVA_HOME": "/home/nikita_demin/.local/share/java/jdk-21",
          "PATH": "/home/nikita_demin/.local/share/java/jdk-21/bin:/home/nikita_demin/.local/bin:/usr/bin:/bin",
        },
      },
    },
    "basedpyright": {
      "settings": {
        "basedpyright": {
          "analysis": {
            "typeCheckingMode": "basic",
          },
        },
      },
    },
    "cucumber": {
      // Prefer the native tree-sitter wrapper; the extension's default WASM
      // bin breaks under hoisted node_modules and reports every step undefined.
      "binary": {
        "path": "~/.local/bin/cucumber-language-server",
        "arguments": ["--stdio"],
      },
      "settings": {
        "features": ["features/**/*.feature"],
        "glue": [
          "step-definitions/**/*.{ts,tsx,js,jsx}",
          "features/**/*.{ts,tsx,js,jsx}",
        ],
        // Enum parameter types registered via helpers (not literal defineParameterType)
        // e2e-repo/step-definitions/cucumber-utils.ts
        "parameterTypes": [
          { "name": "endEffectorPowerStatus", "regexp": "On|Off" },
          {
            "name": "systemStatus",
            "regexp": "Starting|FirstStart|Started|RescueSystem|RebootRequired",
          },
          {
            "name": "recoveryType",
            "regexp": "IdleStatusExceeded|SelfTestsElapsed|GenericJointError|SafetyError|SafeInputUnacknowledged|JointPositionError|JointLimitViolation|SafetyRuleViolation",
          },
          { "name": "fciStatus", "regexp": "Active|Inactive" },
        ],
      },
    },
    "hyperlinks": {
      "settings": {
        "hyperlinkRules": [
          {
            "linkPattern": "(race|artme|artsw|bfftrac|pswb|csr|dtp|te|elo|firm|in|mecha|mbody|prcun|pswh|pswn|ptf|rjh|rovis|ronix|rp|xrl|stss|fr|tpo|puiux|xrob)-\\d+",
            "linkPatternFlags": "i",
            "linkTarget": "https://franka.atlassian.net/browse/$0",
          },
          {
            "linkPattern": "(FX3|SWPL)-[A-Z]+-\\d+",
            "linkTarget": "https://jama.agile-robots.de/perspective.req#/search?term=\"$0\"",
          },
          {
            "linkPattern": "(SysDD)",
            "linkTarget": "https://ar2019test.sharepoint.com/:w:/r/sites/FrankaRDProducts/_layouts/15/Doc.aspx?sourcedoc=%7BEA27A75F-665C-49F0-BE9A-615243792D1D%7D&file=SysDD.docx&action=default&mobileredirect=true",
          },
          {
            "linkPattern": "(ProdMan)",
            "linkTarget": "https://ar2019test.sharepoint.com/sites/FrankaRDProducts/Shared%20Documents/Forms/AllItems.aspx?id=%2Fsites%2FFrankaRDProducts%2FShared%20Documents%2F00%5FGeneral%2FUser%20Documentation%2F02%20Franka%20Research%203%2F01%20Product%20Manual",
          },
          {
            "linkPattern": "(HARA)",
            "linkTarget": "https://ar2019test.sharepoint.com/sites/FrankaRDProducts/Shared%20Documents/Forms/AllItems.aspx?id=%2Fsites%2FFrankaRDProducts%2FShared%20Documents%2F01%20FX3%2F03%5FSystem%2FHARA%5FHazard%5Fand%5FRisk%5FAssesement&viewid=0585ae2a%2Dbc03%2D48f4%2Db14e%2D18f70c21b558&FolderCTID=0x012000A66600AA2CBCB845883613A440F09CC1&ovuser=b158a42f%2D650a%2D44dd%2Da095%2Df9035882b277%2Cdavid%2Ekraus%40franka%2Ede&TeamsCID=5bc38cc8%2D81a5%2D4b31%2Db15e%2Dd69f6fe29175&OR=Teams%2DHL&CT=1782888415831&clickparams=eyJBcHBOYW1lIjoiVGVhbXMtRGVza3RvcCIsIkFwcFZlcnNpb24iOiIxNDE1LzI2MDUyOTA2MTIyIiwiSGFzRmVkZXJhdGVkVXNlciI6ZmFsc2V9",
          },
          {
            "linkPattern": "(CB_SW_Architecture_PlaPlbSF)",
            "linkPatternFlags": "i",
            "linkTarget": "https://ar2019test.sharepoint.com/:w:/r/sites/FrankaRDProducts/_layouts/15/Doc.aspx?sourcedoc=%7B7B4BCD6F-7DA4-4DB7-A010-CA50AF8E284C%7D&file=CB_SW_Architecture_PlaPlbSF.docx",
          },
          {
            "linkPattern": "ISO \\d+",
            "linkPatternFlags": "i",
            "linkTarget": "https://ar2019test.sharepoint.com/sites/AgileRobotsAG/Freigegebene Dokumente/Library/Standards and Regulations/Multi User",
          },
          {
            "linkPattern": "(Impact Analysis:)",
            "linkPatternFlags": "i",
            "linkTarget": "https://ar2019test.sharepoint.com/:f:/r/sites/FrankaRDProducts/Shared%20Documents/01%20FX3/02_Communication/TUV_SUD_Rail?csf=1&web=1&e=Iz8uyl",
          },
          {
            "linkPattern": "(ExtIfSC)",
            "linkTarget": "https://ar2019test.sharepoint.com/:w:/r/sites/FrankaRDProducts/_layouts/15/Doc.aspx?sourcedoc=%7B68BB2AD6-9A89-4771-83CA-2EFE07589561%7D&file=SysDD_IF_External.docx",
          },
          {
            "linkPattern": "(safety-config)",
            "linkTarget": "https://ar2019test.sharepoint.com/:w:/r/sites/FrankaRDProducts/_layouts/15/Doc.aspx?sourcedoc=%7B6C758D33-3879-48FB-88FC-23CA3B035C29%7D&file=Safety_Configuration_Concept.docx",
          },
        ],
      },
    },
  },
}
