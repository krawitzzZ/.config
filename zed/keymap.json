// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "unbind": {
      "ctrl-q": "zed::Quit",
      "ctrl-alt-l": "lsp_tool::ToggleMenu",
      "ctrl-alt-i": "dev::ToggleInspector",
      "shift-escape": "workspace::ToggleZoom",
      "ctrl-shift-w": "workspace::CloseWindow",
    },
    "bindings": {
      "ctrl-`": "workspace::ToggleZoom",
      "ctrl-shift-c": "workspace::CopyRelativePath",
      "ctrl-alt-shift-l": "lsp_tool::ToggleMenu",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-`": "terminal_panel::Toggle",
      "ctrl-n": "workspace::NewFile",
      "ctrl-w": "workspace::CloseActiveDock",
      "ctrl-shift-t": "pane::ReopenClosedItem",
      "ctrl-tab": "tab_switcher::Toggle",
      "ctrl-alt-j": "multi_workspace::ToggleWorkspaceSidebar",
      "ctrl-shift-h": ["pane::DeploySearch", { "replace_enabled": true }],
      "ctrl-shift-x": "zed::Extensions",
    },
    "bindings": {
      "ctrl-alt-[": "workspace::ToggleLeftDock",
      "ctrl-alt-]": "workspace::ToggleRightDock",
      "ctrl-alt-'": "workspace::ToggleBottomDock",
      "ctrl-s": "workspace::Save",
      "alt-s": "workspace::SaveWithoutFormat",
      "ctrl-alt-u": "multi_workspace::ToggleWorkspaceSidebar",
      "ctrl-alt-.": "zed::OpenKeymapFile",
      "ctrl-alt-space": "workspace::CloseAllDocks",
      "ctrl-alt-shift-=": "multi_workspace::CloseWorkspaceSidebar",
      "ctrl-space": [
        "workspace::SendKeystrokes",
        "ctrl-alt-space ctrl-alt-shift-=",
      ],
      "ctrl-shift-tab": "tab_switcher::Toggle",
      "ctrl-alt-shift-x": "zed::Extensions",
      "ctrl-alt-t": "pane::ReopenClosedItem",
      "ctrl-m ctrl-m": "workspace::ToggleZoom",
      "ctrl-shift-m": "workspace::ToggleZoom",
      "ctrl-shift-e": "workspace::ToggleRightDock",
      "ctrl-g ctrl-g": [
        "task::Spawn",
        {
          "task_name": "LazyGit",
          "reveal_target": "center",
        },
      ],
    },
  },
  {
    "context": "TabSwitcher",
    "bindings": {
      "ctrl-shift-tab": "menu::SelectNext",
    },
  },

  {
    "context": "Pane",
    "unbind": {
      "ctrl-w": ["pane::CloseActiveItem", { "close_pinned": false }],
      "ctrl-alt-t": ["pane::CloseOtherItems", { "close_pinned": false }],
      "ctrl-alt-shift-h": "search::ToggleReplace",
      "ctrl-alt-shift-l": "search::ToggleSelection",
    },
    "bindings": {
      "alt-q": ["pane::CloseActiveItem", { "close_pinned": false }],
      "ctrl-alt-h": "search::ToggleReplace",
    },
  },

  {
    "context": "Pane > GitDiff",
    "bindings": {
      "alt-q": ["pane::CloseActiveItem", { "close_pinned": false }],
      "alt-s": "git::ToggleStaged",
      "alt-r": "git::Restore",
    },
  },

  {
    "context": "Editor && VimControl || EmptyPane",
    "bindings": {
      "ctrl-alt-space": "workspace::CloseAllDocks",
      "ctrl-alt-shift-=": "multi_workspace::CloseWorkspaceSidebar",
      "ctrl-space": [
        "workspace::SendKeystrokes",
        "ctrl-alt-space ctrl-alt-shift-=",
      ],
      "space /": "editor::ToggleComments",
      "space q": ["pane::CloseOtherItems", { "close_pinned": false }],
      "space s": "workspace::SaveAll",
      "space e": "pane::RevealInProjectPanel",
      "space d": "diagnostics::DeployCurrentFile",
      "space g": "git::Diff",
      "space b": ["workspace::SendKeystrokes", "space o b ctrl-j"],
      "space t": "git::FileHistory",
      "space f f": "file_finder::Toggle",
      "space o t": "terminal_panel::ToggleFocus",
      "space o a": "agent::ToggleFocus",
      "space o b": "outline_panel::ToggleFocus",
      "space o d": "diagnostics::Deploy",
      "space o D": "debug_panel::ToggleFocus",
      "space o f": "file_finder::Toggle",
      "space o g": "git_panel::ToggleFocus",
      "space o u": "multi_workspace::ToggleWorkspaceSidebar",
      "space o r": "projects::OpenRecent",
    },
  },

  {
    "context": "Editor && !menu && vim_mode != insert",
    "bindings": {
      "tab": "pane::ActivateNextItem",
      "ctrl-tab": "pane::ActivatePreviousItem",
    },
  },
  {
    "context": "Editor && !menu",
    "bindings": {
      "ctrl-c": "editor::Copy",
      "ctrl-f": "buffer_search::Deploy",
      "ctrl-shift-h": "pane::SwapItemLeft",
      "ctrl-shift-l": "pane::SwapItemRight",
      "alt-p": "editor::GoToPreviousReference",
      "alt-n": "editor::GoToNextReference",
    },
  },
  {
    "context": "Editor && !agent_diff",
    "bindings": {
      "alt-s": "git::ToggleStaged",
      "alt-r": "git::Restore",
    },
  },

  {
    "context": "Editor",
    "unbind": {
      "ctrl-space": "editor::ShowCompletions",
      "ctrl-alt-h": "editor::DeleteToPreviousSubwordStart",
      "ctrl-shift-up": ["editor::SelectPrevious", { "replace_newest": false }],
      "ctrl-shift-down": ["editor::SelectNext", { "replace_newest": false }],
      "alt-shift-a": "editor::ToggleBlockComments",
    },
    "bindings": {
      "alt-\\": "editor::ToggleEditPrediction",
      "shift-escape": "editor::ToggleEditPrediction",
      "alt-a": "editor::MoveLineUp",
      "alt-z": "editor::MoveLineDown",
      "ctrl-w h": "workspace::ActivatePaneLeft",
      "ctrl-w l": "workspace::ActivatePaneRight",
      "ctrl-w k": "workspace::ActivatePaneUp",
      "ctrl-w j": "workspace::ActivatePaneDown",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-w ctrl-h": "workspace::MovePaneLeft",
      "ctrl-w ctrl-l": "workspace::MovePaneRight",
      "ctrl-w ctrl-j": "workspace::MovePaneDown",
      "ctrl-w ctrl-k": "workspace::MovePaneUp",
    },
  },

  {
    "context": "Dock",
    "bindings": {
      "ctrl-w h": "workspace::ActivatePaneLeft",
      "ctrl-w l": "workspace::ActivatePaneRight",
      "ctrl-w k": "workspace::ActivatePaneUp",
      "ctrl-w j": "workspace::ActivatePaneDown",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-shift-up": "workspace::IncreaseActiveDockSize",
      "ctrl-shift-down": "workspace::DecreaseActiveDockSize",
      "ctrl-shift-r": "workspace::ResetActiveDockSize",
    },
  },

  {
    "context": "Dock > ProjectPanel && !editing",
    "unbind": {
      "s": "workspace::OpenWithSystem",
      "o": "project_panel::OpenSplitHorizontal",
    },
    "bindings": {
      "space": "pane::TogglePreviewTab",
      "ctrl-alt-space": "workspace::CloseAllDocks",
      "ctrl-alt-shift-=": "multi_workspace::CloseWorkspaceSidebar",
      "ctrl-space": [
        "workspace::SendKeystrokes",
        "ctrl-alt-space ctrl-alt-shift-=",
      ],
      "e": ["workspace::SendKeystrokes", "enter ctrl-alt-b"],
      "s": "project_panel::OpenSplitHorizontal",
      "v": "project_panel::OpenSplitVertical",
      "o": "project_panel::Open",
      "ctrl-h": "project_panel::CollapseSelectedEntryAndChildren",
      "ctrl-l": "project_panel::ExpandSelectedEntryAndChildren",
      "ctrl-shift-j": "project_panel::CollapseAllEntries",
      "ctrl-shift-k": "project_panel::ExpandAllEntries",
    },
  },

  {
    "context": "(Dock > GitPanel) && ChangesList",
    "bindings": {
      "ctrl-alt-space": "workspace::CloseAllDocks",
      "ctrl-alt-shift-=": "multi_workspace::CloseWorkspaceSidebar",
      "ctrl-space": [
        "workspace::SendKeystrokes",
        "ctrl-alt-space ctrl-alt-shift-=",
      ],
      "e": "git::ViewFile",
      "j": "git_panel::NextEntry",
      "k": "git_panel::PreviousEntry",
      "s": "git::ToggleStaged",
      "shift-s": "git::StageAll",
      "space": "menu::Confirm",
      "ctrl-j": "git_panel::FocusEditor",
      "ctrl-d": "git::RestoreFile",
      "ctrl-shift-d": "git::RestoreTrackedFiles",
    },
  },
  {
    "context": "Dock > GitPanel > Editor",
    "bindings": {
      "ctrl-k": "git_panel::FocusChanges",
    },
  },

  {
    "context": "OutlinePanel > Editor",
    "bindings": {
      "ctrl-alt-space": "workspace::CloseAllDocks",
      "ctrl-alt-shift-=": "multi_workspace::CloseWorkspaceSidebar",
      "ctrl-space": [
        "workspace::SendKeystrokes",
        "ctrl-alt-space ctrl-alt-shift-=",
      ],
      "ctrl-j": "menu::Cancel",
      "ctrl-n": "menu::Cancel",
    },
  },
  {
    "context": "OutlinePanel && !editing",
    "bindings": {
      "ctrl-alt-space": "workspace::CloseAllDocks",
      "ctrl-alt-shift-=": "multi_workspace::CloseWorkspaceSidebar",
      "ctrl-space": [
        "workspace::SendKeystrokes",
        "ctrl-alt-space ctrl-alt-shift-=",
      ],
      "space": "menu::Confirm",
      "ctrl-k": "menu::Cancel",
      "ctrl-shift-j": "outline_panel::CollapseAllEntries",
      "ctrl-shift-k": "outline_panel::ExpandAllEntries",
    },
  },

  {
    "context": "(multibuffer || Diagnostics || GitGraph) && vim_mode != insert",
    "bindings": {
      "q": ["pane::CloseActiveItem", { "close_pinned": false }],
      "tab": "pane::ActivateNextItem",
      "ctrl-tab": "pane::ActivatePreviousItem",
      "z a": "editor::ToggleFold",
      "z A": "editor::ToggleFoldAll",
      "ctrl-shift-j": "editor::FoldAll",
      "ctrl-shift-k": "editor::UnfoldAll",
      "ctrl-f": "editor::ToggleFold",
      "ctrl-j": "editor::ToggleFold",
      "ctrl-k": "search::FocusSearch",
      "ctrl-h": "editor::MoveToEndOfPreviousExcerpt",
      "ctrl-l": "editor::MoveToStartOfNextExcerpt",
    },
  },
  {
    "context": "ProjectSearchBar > Editor",
    "bindings": {
      "ctrl-j": "menu::Cancel",
    },
  },

  {
    "context": "GitGraph && !GitGraphSearchBar",
    "bindings": {
      "q": ["pane::CloseActiveItem", { "close_pinned": false }],
    },
  },

  {
    "context": "Terminal",
    "unbind": {
      "ctrl-shift-r": "terminal::RerunTask",
    },
    "bindings": {
      "ctrl-space": "workspace::CloseAllDocks",
      "alt-s": "pane::SplitRight",
      "alt-v": "pane::SplitDown",
      "ctrl-s ctrl-h": "pane::SplitLeft",
      "ctrl-s ctrl-j": "pane::SplitDown",
      "ctrl-s ctrl-k": "pane::SplitUp",
      "ctrl-s ctrl-l": "pane::SplitRight",
    },
  },

  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs",
    "bindings": {
      "q": "vim::MiniQuotes",
      "b": "vim::MiniBrackets",
    },
  },

  {
    "context": "VimControl && !menu",
    "unbind": {
      "q": "vim::ToggleRecord",
    },
    "bindings": {
      "ctrl-alt-q": "vim::ToggleRecord",
      "ctrl-alt-space": "workspace::CloseAllDocks",
      "ctrl-alt-shift-=": "multi_workspace::CloseWorkspaceSidebar",
      "ctrl-space": [
        "workspace::SendKeystrokes",
        "ctrl-alt-space ctrl-alt-shift-=",
      ],
    },
  },
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "g w": "vim::HelixJumpToWord",
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "shift-q": "editor::SelectAll",
      "] g": ["workspace::SendKeystrokes", "escape ] c d o"],
      "[ g": ["workspace::SendKeystrokes", "escape [ c d o"],
    },
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      "shift-s": "vim::PushAddSurrounds",
    },
  },
  {
    "context": "vim_mode == insert",
    "unbind": {
      "ctrl-s": "editor::ShowSignatureHelp",
    },
    "bindings": {
      "alt-space": "editor::ShowSignatureHelp",
      "alt-]": "editor::NextEditPrediction",
      "alt-[": "editor::PreviousEditPrediction",
      "ctrl-space": "editor::ShowCompletions",
      "ctrl-v": "editor::Paste",
      "ctrl-a": "editor::SelectAll",
      "ctrl-q": "editor::MoveToBeginningOfLine",
      "ctrl-t": "editor::MoveToEndOfLine",
      "ctrl-h": "editor::MoveLeft",
      "ctrl-j": "editor::MoveDown",
      "ctrl-k": "editor::MoveUp",
      "ctrl-l": "editor::MoveRight",
    },
  },

  {
    "context": "AgentPanel > Editor",
    "bindings": {
      "tab": null,
      "ctrl-tab": null,
      "ctrl-shift-up": "workspace::IncreaseActiveDockSize",
      "ctrl-shift-down": "workspace::DecreaseActiveDockSize",
      "ctrl-shift-r": "workspace::ResetActiveDockSize",
    },
  },
  {
    "context": "AgentPanel > Editor && showing_completions",
    "bindings": {
      "tab": "editor::ComposeCompletion",
    },
  },

  {
    "context": "ThreadsSidebar || (ThreadsSidebar > Editor) || (ThreadsSidebar > ThreadsArchiveView)",
    "bindings": {
      "ctrl-alt-space": "workspace::CloseAllDocks",
      "ctrl-alt-shift-=": "multi_workspace::CloseWorkspaceSidebar",
      "ctrl-space": [
        "workspace::SendKeystrokes",
        "ctrl-alt-space ctrl-alt-shift-=",
      ],
      "space": ["workspace::SendKeystrokes", "enter ctrl-alt-shift-="],
      "ctrl-n": "editor::MoveDown",
      "ctrl-p": "editor::MoveUp",
      "ctrl-alt-h": "agents_sidebar::ToggleThreadHistory",
      "ctrl-w l": "workspace::ActivatePaneRight",
      "ctrl-l": "workspace::ActivatePaneRight",
    },
  },
  {
    "context": "(ThreadsSidebar && searching) > Editor",
    "bindings": {
      "ctrl-j": "editor::MoveDown",
    },
  },
  {
    "context": "ThreadsSidebar && !searching",
    "bindings": {
      "ctrl-j": null,
      "ctrl-k": "menu::Cancel",
    },
  },

  {
    "context": "AcpThread || AcpThread > Editor",
    "unbind": {
      "ctrl-alt-a": "agent::OpenPermissionDropdown",
    },
    "bindings": {
      "alt-a": "agent::AllowOnce",
      "alt-x": "agent::RejectOnce",
      "ctrl-alt-a": "agent::AllowAlways",
    },
  },

  {
    "context": "WorktreePicker || WorktreePicker > Picker > Editor",
    "bindings": {
      // "alt-q": "worktree_picker::RemoveWorktreeFromWindow",
      "ctrl-d": "worktree_picker::DeleteWorktree",
      "ctrl-shift-d": "worktree_picker::ForceDeleteWorktree",
    },
  },

  {
    "context": "FileFinder > Picker > Editor",
    "bindings": {
      "ctrl-h": "pane::SplitLeft",
      "ctrl-l": "pane::SplitRight",
      "ctrl-j": "pane::SplitDown",
      "ctrl-k": "pane::SplitUp",
    },
  },

  {
    "context": "EmptyPane",
    "bindings": {
      "q": ["pane::CloseActiveItem", { "close_pinned": false }],
    },
  },

  // Unbinds

  {
    "context": "GitPanel && ChangesList && !GitBranchSelector",
    "unbind": {
      "space": "git::ToggleStaged",
    },
  },
  {
    "context": "SettingsWindow",
    "unbind": {
      "ctrl-w": "workspace::CloseWindow",
    },
  },
  {
    "context": "SkillCreator",
    "unbind": {
      "ctrl-w": "workspace::CloseWindow",
    },
  },
  {
    "context": "SkillCreator > Editor",
    "unbind": {
      "ctrl-w": "workspace::CloseWindow",
    },
  },
  {
    "context": "CommitEditor > Editor",
    "unbind": {
      "shift-escape": "git::ExpandCommitEditor",
    },
  },
  {
    "context": "!Terminal",
    "unbind": {
      "ctrl-shift-c": "collab_panel::ToggleFocus",
    },
  },
  {
    "context": "AcpThread > Editor",
    "unbind": {
      "ctrl-alt-'": "agent::ToggleThinkingEffortMenu",
    },
  },
  {
    "context": "AcpThread",
    "unbind": {
      "alt-shift-a": "agent::AllowOnce",
      "alt-shift-q": "agent::AllowAlways",
    },
  },
  {
    "context": "Welcome",
    "unbind": {
      "ctrl-n": "workspace::NewFile",
    },
  },

  // Changes from the UI keymap editor
]
